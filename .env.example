# Copy this file to .env and fill in your own values.
# Never commit .env — it is listed in .gitignore.

# ── AI ──────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── External review APIs ─────────────────────────────────────────
# TMDb (movies) — free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Google Books — enable Books API in https://console.cloud.google.com
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# ── Flask ────────────────────────────────────────────────────────
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# ── Environment ──────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=text              # text | json

# ── Redis / async jobs ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
ASYNC_ENABLED=true

# ── AI service tuning ────────────────────────────────────────────
AI_TIMEOUT_SECONDS=15
AI_RETRY_COUNT=2
AI_RETRY_BACKOFF_SECONDS=0.5
CACHE_TTL_SECONDS=86400
